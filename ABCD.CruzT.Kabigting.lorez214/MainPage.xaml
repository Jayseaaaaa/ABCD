ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyApp.MainPage">

    <Grid RowDefinitions="Auto,*,Auto,Auto" Padding="10">

        <!-- Search Bar -->
        <SearchBar x:Name="SearchBar"
                   Placeholder="Search location..."
                   SearchButtonPressed="OnSearchPressed" />

        <!-- Map -->
        <Map x:Name="MainMap"
             Grid.Row="1"
             IsShowingUser="True" />

        <!-- Stats Bar -->
        <Grid Grid.Row="2" ColumnDefinitions=",,*"
              BackgroundColor="#EEE" Padding="10">

            <StackLayout>
                <Label Text="Time" FontAttributes="Bold"/>
                <Label x:Name="TimeLabel" Text="00:00"/>
            </StackLayout>

            <StackLayout Grid.Column="1">
                <Label Text="Speed" FontAttributes="Bold"/>
                <Label x:Name="SpeedLabel" Text="0.0"/>
            </StackLayout>

            <StackLayout Grid.Column="2">
                <Label Text="Distance" FontAttributes="Bold"/>
                <Label x:Name="DistanceLabel" Text="0.0"/>
            </StackLayout>

        </Grid>

        <!-- Bottom Buttons -->
        <Grid Grid.Row="3" ColumnDefinitions=",,*"
              Padding="10">

            <Button Text="📂"
                    Clicked="OnHistoryClicked"/>

            <Button Text="▶"
                    Grid.Column="1"
                    Clicked="OnStartClicked"/>

            <Button Text="?"
                    Grid.Column="2"
                    Clicked="OnHelpClicked"/>

        </Grid>

    </Grid>
</ContentPage>
